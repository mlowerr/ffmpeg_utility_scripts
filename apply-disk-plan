#!/usr/bin/env bash
# Apply a generated disk plan.
#
# Optional flags let callers override the disk size display type and generated
# base name without relying on environment variables.

set -u
shopt -s nullglob nocaseglob

DISK_SIZE_TYPE="${DISK_SIZE_TYPE:-}"
BASE_NAME="${BASE_NAME:-}"
PLAN_FILE="${PLAN_FILE:-disk-plan.sh}"
DRY_RUN=false

usage() {
    cat <<USAGE
Usage: $0 [--disk-size-type type] [--base-name name] [--plan-file path] [--dry-run]

Options:
  --disk-size-type, --disk-type, --type  Disk size/type value to expose to the plan.
  --base-name name                      Base name value to expose to the plan.
  --plan-file path                      Plan file to apply (default: disk-plan.sh).
  --dry-run                             Print the resolved plan settings only.
  -h, --help                            Show this help text.

Environment fallback variables: DISK_SIZE_TYPE, BASE_NAME, PLAN_FILE.
USAGE
}

need_value() {
    if [[ $# -lt 2 || -z "${2:-}" ]]; then
        printf 'Error: %s requires a value.\n' "$1" >&2
        usage >&2
        exit 1
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --disk-size-type|--disk-type|--type)
            need_value "$1" "${2-}"
            DISK_SIZE_TYPE="$2"
            shift 2
            ;;
        --base-name)
            need_value "$1" "${2-}"
            BASE_NAME="$2"
            shift 2
            ;;
        --plan-file)
            need_value "$1" "${2-}"
            PLAN_FILE="$2"
            shift 2
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            printf 'Error: Unknown option: %s\n' "$1" >&2
            usage >&2
            exit 1
            ;;
    esac
done

export DISK_SIZE_TYPE
export BASE_NAME

if [[ "$DRY_RUN" == true ]]; then
    printf 'PLAN_FILE=%s\n' "$PLAN_FILE"
    printf 'DISK_SIZE_TYPE=%s\n' "$DISK_SIZE_TYPE"
    printf 'BASE_NAME=%s\n' "$BASE_NAME"
    exit 0
fi

if [[ ! -f "$PLAN_FILE" ]]; then
    printf 'Error: Plan file not found: %s\n' "$PLAN_FILE" >&2
    exit 1
fi

bash "$PLAN_FILE"
